# ============================================================
# Keevan Blog — Environment Variables
# ============================================================
# Copy this file to `.env` (local dev) or set these in your Vercel
# project settings → Settings → Environment Variables.
# ============================================================

# ---- DATABASE ----
# LOCAL DEV (SQLite file — sandbox/next dev):
DATABASE_URL=file:/home/z/my-project/db/custom.db

# PRODUCTION (Turso libsql):
# 1. Sign up at https://turso.tech
# 2. Run: turso db create keevan-blog
# 3. Get URL:  turso db show keevan-blog --url
# 4. Get token: turso db tokens create keevan-blog
# 5. Replace values below in Vercel env vars
# DATABASE_URL=libsql://keevan-blog-xxx.turso.io
# TURSO_AUTH_TOKEN=eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9...

# ---- Z.AI API ----
# Get your key from https://z.ai → API Keys
# IMPORTANT: Do NOT commit this key to git. Only set it in .env.local
# (gitignored) or in Vercel env vars.
ZAI_API_KEY=your-z-ai-api-key-here

# Model to use for article generation. Defaults to glm-4.7-flash if not set.
ZAI_MODEL=glm-4.7-flash

# ---- AUTH ----
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=https://blog.keevanstore.in
ADMIN_PASSWORD=your-admin-password

# ---- VERCEL (auto-set by Vercel, don't set locally) ----
# VERCEL=1
# VERCEL_ENV=production

# ---- OPTIONAL: SITE URL OVERRIDE ----
# Used for canonical URLs / sitemap / RSS feed. Defaults to
# https://blog.keevanstore.in (set in src/lib/site-config.ts)
# SITE_URL=https://blog.keevanstore.in
